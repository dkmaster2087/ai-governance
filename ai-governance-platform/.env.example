POLICIES_TABLE=ai-gov-policies-dev
METRICS_TABLE=ai-gov-metrics-dev

# AI Providers
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Analytics
ATHENA_DATABASE=ai_gov_logs_dev
